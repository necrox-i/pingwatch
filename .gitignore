#gitignore for a monorepo with multiple services (Node, Terraform, Kubernetes, Helm, Ansible)

# ----------------------
# OS / Editor
# ----------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# ----------------------
# Logs
# ----------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----------------------
# Environment / Secrets
# ----------------------
.env
*.env
*.local
*.key
*.pem
*.crt

# ----------------------
# Node (ALL SERVICES)
# ----------------------
node_modules/
dist/
build/
.next/
out/
coverage/
*.tsbuildinfo

# ----------------------
# Package managers
# ----------------------
.pnpm-store/
.npm/
.yarn/
.yarn-cache/
.yarnrc

# ----------------------
# Testing
# ----------------------
coverage/
jest-report/

# ----------------------
# Terraform
# ----------------------
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/*.tfstate
terraform/*.tfstate.*
terraform/crash.log

# ----------------------
# Kubernetes
# ----------------------
*.secret.yaml
*.secret.yml
kubeconfig*
*.kubeconfig

# ----------------------
# Helm (chart/)
# ----------------------
chart/*.tgz
chart/charts/

# ----------------------
# Ansible
# ----------------------
ansible/*.retry

# ----------------------
# Misc build artifacts
# ----------------------
*.out
*.tmp
*.cache

# ----------------------
# Optional: lockfiles (ONLY ignore if you intentionally don't want them)
# ----------------------
# package-lock.json
# yarn.lock
# pnpm-lock.yaml